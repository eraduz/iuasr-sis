# ==================================================================
# IUASR Management Systeem — .env voorbeeld
#
# Dit bestand bevat ALLEEN wat per omgeving verschilt. Alle gedeelde
# instellingen (tijdzone, taal, cijfernormen, presentienorm, nummer-
# formaten, collegegeldtermijnen, HR-normen, AVG-schakelaars) staan in
# `config/app.php`, `config/session.php` en `config/sis.php` en komen dus
# automatisch mee met `git pull`. U hoeft ze NIET over te typen.
#
# Zo zet u een omgeving op:
#   1. cp .env.example .env
#   2. de waarden hieronder invullen
#   3. php artisan optimize:clear
#
# Na ELKE wijziging in .env:  php artisan optimize:clear
# ==================================================================

# ------------------------------------------------------------------
# APP_KEY — de ENIGE gedeelde waarde die hier hoort te staan.
#
# BSN, rekeningnummer en de sessies worden hiermee versleuteld. Wie een
# databasesnapshot van de ene omgeving in de andere terugzet (sis:snapshot /
# sis:restore), moet daar DEZELFDE APP_KEY hebben — anders zijn die velden
# onleesbaar. Kies dus EEN sleutel voor ontwikkeling, RDP en Plesk samen.
#
#   Genereren (eenmalig):  php artisan key:generate --show
#
# Bewaar de sleutel in een wachtwoordkluis. Commit hem NOOIT.
# ------------------------------------------------------------------
APP_KEY=

# ------------------------------------------------------------------
# Omgeving
#   ontwikkeling : local      / APP_DEBUG=true  / LOG_LEVEL=debug
#   RDP (test)   : testing    / APP_DEBUG=true  / LOG_LEVEL=debug
#   Plesk        : production / APP_DEBUG=false / LOG_LEVEL=warning
#
# APP_DEBUG=true op productie lekt stacktraces met persoonsgegevens.
# ------------------------------------------------------------------
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=debug

# De URL waarop DEZE omgeving wordt benaderd. Moet kloppen: de Entra-redirect
# en de links in e-mails worden hiervan afgeleid.
#   ontwikkeling : http://127.0.0.1:8000
#   RDP          : https://iuasr-sis.local
#   Plesk        : de Plesk-URL
APP_URL=http://127.0.0.1:8000

# ------------------------------------------------------------------
# Database — eigen naam en eigen inloggegevens per omgeving. Elke omgeving
# heeft een EIGEN, gescheiden database. Lokaal draait MariaDB op poort 3307
# (zie scripts/db-start.ps1); standaard MySQL/MariaDB luistert op 3306.
# ------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=iuasr_sis
DB_USERNAME=iuasr_sis
DB_PASSWORD=

# ------------------------------------------------------------------
# Sessiecookie alleen over HTTPS versturen.
#   ontwikkeling (http)  : false
#   RDP en Plesk (https) : true
# Staat dit op true terwijl de site over http draait, dan stuurt de browser de
# cookie niet terug en krijgt u bij elk formulier 419 Page Expired.
# ------------------------------------------------------------------
SESSION_SECURE_COOKIE=false

# ------------------------------------------------------------------
# Interne netwerkbeperking (komma-gescheiden IP-adressen/CIDR). Wordt afgedwongen
# door de middleware IpBeperking op ELK verzoek — ook op het inlogscherm en op de
# publieke bibliotheekpagina (/bibliotheek-zoeken).
#
# LEEG = GEEN FILTER; dat is UITSLUITEND toegestaan bij lokale ontwikkeling.
# Op de RDP hoort hier het interne bereik van het pand te staan:
#   SIS_TOEGESTANE_IPS=192.168.16.0/24
# LET OP: op Plesk (bereikbaar via internet) ziet de server niet het interne maar
# het PUBLIEKE IP van het pand. Vul daar dus het vaste externe IP-adres in; het
# interne bereik zou daar iedereen buitensluiten.
# ------------------------------------------------------------------
SIS_TOEGESTANE_IPS=

# ------------------------------------------------------------------
# Noodtoegang (break-glass) — /noodtoegang
# Maximaal TWEE beheerdersaccounts loggen hier met gebruikersnaam+wachtwoord in
# als Entra ID onbereikbaar is. Het maximum van twee staat vast in de database en
# is NIET via env te wijzigen. Reguliere accounts hebben geen wachtwoord.
#
# Het eerste wachtwoord zet u op de server met:
#   php artisan sis:noodaccount-instellen <e-mailadres>
#
# De noodtoegang valt onder SIS_TOEGESTANE_IPS hierboven: uitsluitend vanaf het
# interne netwerk. Van buiten werken betekent eerst de VPN op — er is bewust GEEN
# uitzondering, die zou de enige wachtwoorddeur aan het internet blootstellen.
#
# LET OP: zet op productie ook SESSION_SECURE_COOKIE=true (zie hierboven) en dwing
# HTTPS af in de vhost. Anders gaat het noodwachtwoord leesbaar over de lijn.
# ------------------------------------------------------------------
SIS_NOODACCOUNT_WACHTWOORD_MIN_LENGTE=16
SIS_NOODACCOUNT_MAX_POGINGEN=5
SIS_NOODACCOUNT_MAX_POGINGEN_PER_IP=20

# ------------------------------------------------------------------
# Microsoft Entra ID (SSO/OIDC) — bouw NOOIT een eigen login.
# Tenant en client zijn op elke omgeving gelijk; de REDIRECT_URI volgt APP_URL
# en verschilt dus per machine. Elke omgeving moet met haar eigen redirect-URI
# geregistreerd staan in de app-registratie in Entra.
# ------------------------------------------------------------------
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI="${APP_URL}/auth/entra/callback"

# ------------------------------------------------------------------
# E-mail. Bij ontwikkeling en test schrijft 'log' de berichten naar
# storage/logs/laravel.log in plaats van ze echt te versturen — zo bereikt geen
# enkele testmail een echte student of medewerker. Op Plesk: 'smtp' met de
# gegevens van de mailserver.
#   ontwikkeling / RDP : MAIL_MAILER=log
#   productie (M365)   : MAIL_MAILER=graph  (Microsoft Graph API, aanbevolen)
#   terugval           : MAIL_MAILER=smtp   (alleen als SMTP AUTH is toegestaan)
# ------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@iuasr.nl
MAIL_FROM_NAME="IUASR Management Systeem"

# --- Microsoft 365 via Graph API (MAIL_MAILER=graph) ---
# Entra ID app-registratie met application-permission Mail.Send (+ admin consent).
# MS_GRAPH_FROM is de verzendmailbox (mag een GEDEELDE mailbox zijn), afgeschermd
# met een Application Access Policy. Zie de technische handleiding.
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# MS_GRAPH_FROM=examencommissie@iuasr.nl

# --- SMTP (terugval; office365 basic auth vaak uitgeschakeld) ---
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# ------------------------------------------------------------------
# Pad naar een CA-bundel (cacert.pem) voor het ophalen van onderwijsnieuws, als
# de server die niet globaal in php.ini heeft staan. Machine-afhankelijk pad.
# SSL-verificatie blijft altijd AAN.
# ------------------------------------------------------------------
SIS_NIEUWS_CACERT=
