APP_NAME="IUASR Management Systeem"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=nl
APP_FALLBACK_LOCALE=nl
APP_FAKER_LOCALE=nl_NL

APP_TIMEZONE=Europe/Amsterdam

# ------------------------------------------------------------------
# AVG: uitsluitend synthetische data in ontwikkeling. Verbind NOOIT
# een ontwikkelomgeving met een productiedatabase of echte gegevens.
# ------------------------------------------------------------------

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=iuasr_sis
DB_USERNAME=iuasr_sis
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

CACHE_STORE=database
QUEUE_CONNECTION=database

# ------------------------------------------------------------------
# Microsoft Entra ID (SSO/OIDC) — GEEN eigen login bouwen.
# Waarden volgen uit de app-registratie in Entra; hier leeg laten
# tot ze door de beheerder zijn aangeleverd.
# ------------------------------------------------------------------
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI="${APP_URL}/auth/entra/callback"

# ------------------------------------------------------------------
# Openstaande parameters (TE BEVESTIGEN door de opdrachtgever) —
# niet zelf invullen met een aanname; zie config/sis.php en PROGRESS.md.
# ------------------------------------------------------------------
# Aantal cijfers na de jaarprefix in het studentnummer (bron: 5 OF 6).
SIS_STUDENTNUMMER_CIJFERS=

# Interne netwerkbeperking (komma-gescheiden IP-adressen/CIDR).
SIS_TOEGESTANE_IPS=

# Collegegeld: factuur op de FACTUURDAG van de vervalmaand, daarna een
# betaaltermijn. Vervaldatum = factuurdag + betaaltermijn (14 + 10 = de 24e).
SIS_COLLEGEGELD_FACTUURDAG=14
SIS_COLLEGEGELD_BETAALTERMIJN_DAGEN=10
