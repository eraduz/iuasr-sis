# ==========================================================================
# IUASR Management Systeem — .gitignore
# HARDE REGEL: er komt NOOIT een productiedatabase of echte persoonsgegevens
# in deze repo, in geen enkele fase. Zie PROGRESS.md (AVG-grenzen).
# ==========================================================================

# --- Databasebestanden (Access, SQLite, dumps met data) -------------------
*.mdb
*.accdb
*.ldb
*.laccdb
*.sqlite
*.sqlite3
*.db
*.sql
*.dump
*.bak
# Expliciet: de oude productie-Access-database mag nooit gecommit worden
IUTSTD-*.mdb

# --- Secrets en omgeving --------------------------------------------------
.env
.env.*
!.env.example
# .env.testing hoort WEL in Git: zonder dat bestand valt `--env=testing` terug op
# de gewone .env en dus op de ONTWIKKELdatabase. Een `migrate:fresh --env=testing`
# wiste zo op 2026-07-17 de hele ontwikkeldatabase. Het bevat geen geheimen —
# dezelfde lokale testgegevens staan al in phpunit.xml. Niet verwijderen.
!.env.testing
*.pem
*.key
*.p12
*.pfx
.my.cnf
.netrc
auth.json
secrets.*
# Uitgeschreven .env-inhoud per omgeving (bevat de APP_KEY)
rdp_env.md
plesk_env.md

# --- Mappen met echte of gevoelige data -----------------------------------
/data-echt/
/data-productie/
/uploads-prive/
/migratie-bron/
/persoonsgegevens/

# --- PHP / Laravel --------------------------------------------------------
/vendor/
/storage/*.key
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
/bootstrap/cache/*
/public/storage
/public/hot
composer.phar

# --- Node / frontend build ------------------------------------------------
/node_modules/
/public/build/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- IDE / OS ------------------------------------------------------------
/.idea/
/.vscode/
*.swp
.DS_Store
Thumbs.db
Desktop.ini

# --- Overige artefacten ---------------------------------------------------
*.log
.phpunit.result.cache
/coverage/

# --- Design-bronmateriaal -------------------------------------------------
# Alleen het LEIDENDE SIS-design system wordt getrackt. De overige mappen
# onder IUASR/ (homepage, aanmeldportaal, pages, uploads, screencaptures) horen
# bij een andere/publieke site en zijn bulky; die blijven buiten Git. Wat de
# applicatie nodig heeft staat al in public/assets/.
/IUASR/*
!/IUASR/iuasr-sis/
!/IUASR/assets/
!/IUASR/IUASR Design System.html

# Echte personeelslijst (AVG): namen/functies van medewerkers — niet in Git.
database/data/personeel.csv

# DB-snapshots (testdata; buiten Git)
/storage/app/db-snapshots/
