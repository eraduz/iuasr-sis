# ==========================================================================
# IUASR Management Systeem — .gitignore
# HARDE REGEL: er komt NOOIT een productiedatabase of echte persoonsgegevens
# in deze repo, in geen enkele fase. Zie PROGRESS.md (AVG-grenzen).
# ==========================================================================

# --- Databasebestanden (Access, SQLite, dumps met data) -------------------
*.mdb
*.accdb
*.ldb
*.laccdb
*.sqlite
*.sqlite3
*.db
*.sql
*.dump
*.bak
# Expliciet: de oude productie-Access-database mag nooit gecommit worden
IUTSTD-*.mdb

# --- Secrets en omgeving --------------------------------------------------
.env
.env.*
!.env.example
# .env.testing hoort NIET in Git, ook al is het een vangnet tegen
# `--env=testing` op de ontwikkeldatabase: het bevat de inloggegevens van de
# machine waar het staat. Eén dag met dat bestand in Git kostte de RDP zijn
# werkende omgeving (ander databasewachtwoord + `artisan serve` geeft APP_ENV
# door aan de webserver ⇒ elk webverzoek op de testdatabase). Het wordt nu per
# machine afgeleid uit .env door scripts/env-testing.ps1; zie .env.testing.example.
!.env.testing.example
*.pem
*.key
*.p12
*.pfx
.my.cnf
.netrc
auth.json
secrets.*
# Uitgeschreven .env-inhoud per omgeving (bevat de APP_KEY)
rdp_env.md
plesk_env.md

# --- Mappen met echte of gevoelige data -----------------------------------
/data-echt/
/data-productie/
/uploads-prive/
/migratie-bron/
/persoonsgegevens/

# --- PHP / Laravel --------------------------------------------------------
/vendor/
/storage/*.key
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
/bootstrap/cache/*
/public/storage
/public/hot
composer.phar

# --- Node / frontend build ------------------------------------------------
/node_modules/
/public/build/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- IDE / OS ------------------------------------------------------------
/.idea/
/.vscode/
*.swp
.DS_Store
Thumbs.db
Desktop.ini

# --- Overige artefacten ---------------------------------------------------
*.log
.phpunit.result.cache
/coverage/

# --- Design-bronmateriaal -------------------------------------------------
# Alleen het LEIDENDE SIS-design system wordt getrackt. De overige mappen
# onder IUASR/ (homepage, aanmeldportaal, pages, uploads, screencaptures) horen
# bij een andere/publieke site en zijn bulky; die blijven buiten Git. Wat de
# applicatie nodig heeft staat al in public/assets/.
/IUASR/*
!/IUASR/iuasr-sis/
!/IUASR/assets/
!/IUASR/IUASR Design System.html

# Echte personeelslijst (AVG): namen/functies van medewerkers — niet in Git.
database/data/personeel.csv

# DB-snapshots (testdata; buiten Git)
/storage/app/db-snapshots/
