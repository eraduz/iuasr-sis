# ── Toegang beperken tot toegestane IP's ──────────────────────────────────────
# Plesk draait mod_remoteip, dus Apache ziet het echte bezoekers-IP in REMOTE_ADDR.
# Staat het IP er niet tussen -> 403 Forbidden. IP toevoegen? Regel aanvullen + push.
<IfModule mod_authz_core.c>
    Require ip 37.251.61.41 24.132.214.178 109.36.146.250 178.226.112.182 178.230.61.75 62.45.104.234 178.230.61.122 178.230.1.68
</IfModule>

<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Behandel Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Herstuur trailing slashes indien niet een map...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Stuur verzoeken naar de front controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
