<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # ── TIJDELIJK DEBUG: toon het IP dat de server ziet in de URL-balk ─────────
    # (blokkade staat even uit; verwijderen zodra we het juiste IP weten)
    RewriteCond %{QUERY_STRING} !ipdebug
    RewriteRule ^(|login)$ /login?ipdebug=1&xff=%{HTTP:X-Forwarded-For}&remote=%{REMOTE_ADDR} [R=302,L,NE]

    # Behandel Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Herstuur trailing slashes indien niet een map...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Stuur verzoeken naar de front controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
