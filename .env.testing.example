# ============================================================================
# .env.testing — VOORBEELD. Het echte bestand staat NIET in Git en wordt per
# machine afgeleid uit uw eigen .env door `scripts/env-testing.ps1` (dat draait
# automatisch bij `.\scripts\dev.ps1`).
#
# WAAROM HET MOET BESTAAN
# `php artisan <commando> --env=testing` laadt .env.testing. Bestaat dat niet,
# dan valt Laravel STILZWIJGEND terug op de gewone .env — en die wijst naar de
# ONTWIKKELdatabase. Zo is op 17-07-2026 de complete ontwikkeldatabase gewist
# met een `migrate:fresh --env=testing`. De <env>-regels in phpunit.xml helpen
# daar niet tegen: die gelden alleen ónder phpunit, niet bij een los commando.
#
# WAAROM HET NIET IN GIT STAAT
# Het bevat het databasewachtwoord van uw machine. Toen het één dag wél in Git
# stond, brak de RDP: die had een ander wachtwoord, en `php artisan serve` geeft
# APP_ENV door aan het webserverproces (ServeCommand::$passthroughVariables),
# waardoor elk webverzoek daar ineens op de testdatabase uitkwam.
#
# LET OP: zet in uw gewone .env `APP_ENV=local`, niet `testing`. Met `testing`
# komen ook uw webverzoeken op de testdatabase uit.
# ============================================================================
APP_ENV=testing
APP_DEBUG=true
APP_KEY=base64:VUL_DEZELFDE_SLEUTEL_IN_ALS_IN_UW_ENV

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
# ALTIJD de ontwikkeldatabase + _test — nooit dezelfde naam als in .env.
DB_DATABASE=iuasr_sis_test
DB_USERNAME=iuasr_sis
DB_PASSWORD=HETZELFDE_ALS_IN_UW_ENV

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=log

# Geen netwerkbeperking in tests.
SIS_TOEGESTANE_IPS=
