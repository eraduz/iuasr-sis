# ------------------------------------------------------------------
# Testomgeving — WORDT BEWUST MEEGELEVERD IN GIT.
#
# WAAROM DIT BESTAAND MOET BLIJVEN:
# `php artisan <commando> --env=testing` laadt dit bestand. Bestaat het NIET,
# dan valt Laravel stilzwijgend terug op de gewone `.env` — en die wijst naar de
# ONTWIKKELDATABASE (iuasr_sis). Een `php artisan migrate:fresh --env=testing`
# gooide op 2026-07-17 zo de complete ontwikkeldatabase leeg: alle studenten,
# cijfers en de hele bibliotheekimport. De <env>-regels in phpunit.xml gelden
# namelijk alleen ONDER phpunit, niet bij een los artisan-commando.
#
# Dit bestand is het vangnet: --env=testing komt hierdoor ALTIJD op
# iuasr_sis_test uit, nooit op de ontwikkeldatabase.
#
# Er staan geen geheimen in: dit zijn dezelfde lokale ontwikkelgegevens die al
# in phpunit.xml staan. Houd beide bestanden gelijk.
# ------------------------------------------------------------------
APP_ENV=testing
APP_DEBUG=true

# Wegwerpsleutel, UITSLUITEND voor de testdatabase. Staat bewust in Git: `php
# artisan test` zet APP_ENV=testing en laadt dus dit bestand in plaats van .env;
# zonder sleutel hier faalt elke test die een pagina rendert (sessies worden
# versleuteld). Deze sleutel versleutelt niets van waarde — de testdatabase wordt
# bij elke run weggegooid.
# DIT IS NIET DE PRODUCTIESLEUTEL: die staat alleen in de .env op de server en
# hoort nergens in Git (zonder die sleutel zijn BSN en rekeningnummer niet meer te
# ontsleutelen — zie de technische handleiding, hoofdstuk back-up en herstel).
APP_KEY=base64:pSbPS3C1UhS/7EZwNixdYw9pShDrzhmNIUkeHQ1lk/Y=

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=iuasr_sis_test
DB_USERNAME=iuasr_sis
DB_PASSWORD=iuasr_sis_dev

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=log

# Geen netwerkbeperking in tests.
SIS_TOEGESTANE_IPS=
